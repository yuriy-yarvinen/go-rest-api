# DB_DRIVER selects the backend: "sqlite" (default) or "postgres".
DB_DRIVER=sqlite

# Used when DB_DRIVER=sqlite.
DB_PATH=./api.db

# Used when DB_DRIVER=postgres (read by the Go app).
# DB_HOST: "postgres" (compose service name) when run via docker-compose,
# "localhost" when running the app directly against a local Postgres.
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=go_rest_api
DB_SSLMODE=disable

# Read by the official postgres image itself to initialize the cluster.
# Keep these in sync with DB_USER / DB_PASSWORD / DB_NAME above.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=go_rest_api

# CACHE_ENABLED turns on the Redis read cache for events/users GET lookups.
# Off by default so local (non-Docker) dev doesn't need Redis running.
# REDIS_HOST: "redis" (compose service name) when run via docker-compose,
# "localhost" when running the app directly against a local Redis.
CACHE_ENABLED=false
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
